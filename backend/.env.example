# Supabase (Tu URL de proyecto y API Key de tipo "service_role" para saltar RLS desde el servidor)
SUPABASE_URL="https://tu-proyecto.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="tu_jwt_service_role_key_aqui"

# Google Gemini API Key (Para el análisis de sentimientos)
GEMINI_API_KEY="tu_google_gemini_api_key_aqui"

# Puerto en el que se ejecuta el servidor Backend (Opcional, predeterminado a 3001)
PORT=3001
